generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------
// ENUMS
// ---------------------------------------------------------

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  STAFF
  ACCOUNTANT
}

enum Status {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum WarehouseType {
  MAIN
  BRANCH
  VIRTUAL
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
  TRANSFER
}

enum StockMovementReferenceType {
  PURCHASE_ORDER
  SALES_ORDER
  MANUAL
  TRANSFER
}

enum PurchaseOrderStatus {
  PENDING
  APPROVED
  COMPLETED
  CANCELLED
}

enum SalesOrderStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  RETURNED
  PARTIALLY_COMPLETED
}

enum PaymentType {
  PURCHASE
  SALES
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  BANK_TRANSFER
  CHEQUE
  PAYPAL
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum AuditLogAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  CANCEL
}

enum AuditLogEntity {
  PRODUCT
  CATEGORY
  SUPPLIER
  PURCHASE_ORDER
  SALES_ORDER
  STOCK
  PAYMENT
  INVOICE
}

enum ActivityType {
  LOGIN
  LOGOUT
  PASSWORD_CHANGE
  PROFILE_UPDATE
  STOCK_ADJUSTMENT
}

// ---------------------------------------------------------
// MODELS
// ---------------------------------------------------------

/// Represents a user block in the system.
model User {
  id        String  @id @default(cuid())
  firstName String
  lastName  String
  email     String  @unique
  password  String
  phone     String?
  avatarUrl String?
  role      Role    @default(STAFF)
  status    Status  @default(ACTIVE)

  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Self relations for auditing
  createdById String?
  updatedById String?
  deletedById String?
  createdBy   User?   @relation("UserCreatedBy", fields: [createdById], references: [id])
  updatedBy   User?   @relation("UserUpdatedBy", fields: [updatedById], references: [id])
  deletedBy   User?   @relation("UserDeletedBy", fields: [deletedById], references: [id])

  // Reverse relations for auditing others
  createdUsers User[] @relation("UserCreatedBy")
  updatedUsers User[] @relation("UserUpdatedBy")
  deletedUsers User[] @relation("UserDeletedBy")

  // Relations
  warehousesManaged Warehouse[]
  purchaseOrders    PurchaseOrder[]
  salesOrders       SalesOrder[]
  auditLogs         AuditLog[]
  activityLogs      ActivityLog[]

  @@index([email])
  @@index([role])
}

/// Represents a module-level permission mapping for roles
model RolePermission {
  id        String  @id @default(cuid())
  role      Role
  module    String // e.g., Products, Categories, Stock, Orders, Payments, Reports
  canCreate Boolean @default(false)
  canRead   Boolean @default(false)
  canUpdate Boolean @default(false)
  canDelete Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([role, module])
}

/// Represents a product in the inventory
model Product {
  id          String   @id @default(cuid())
  sku         String   @unique
  name        String
  description String?
  price       Decimal  @db.Decimal(12, 2)
  costPrice   Decimal  @db.Decimal(12, 2)
  weight      Decimal? @db.Decimal(10, 2)
  height      Decimal? @db.Decimal(10, 2)
  width       Decimal? @db.Decimal(10, 2)
  length      Decimal? @db.Decimal(10, 2)
  barcode     String?  @unique

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])

  isActive Boolean @default(true)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  stocks             Stock[]
  stockMovements     StockMovement[]
  purchaseOrderItems PurchaseOrderItem[]
  salesOrderItems    SalesOrderItem[]

  @@index([sku])
  @@index([name])
  @@index([categoryId])
  @@index([supplierId])
}

/// Represents a product category
model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  description String?

  parentCategoryId String?
  parentCategory   Category?  @relation("SubCategories", fields: [parentCategoryId], references: [id])
  subCategories    Category[] @relation("SubCategories")

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  products Product[]
}

/// Represents a supplier providing products
model Supplier {
  id          String  @id @default(cuid())
  name        String
  contactName String?
  email       String?
  phone       String?
  address     String?
  taxId       String?
  notes       String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  products       Product[]
  purchaseOrders PurchaseOrder[]

  @@index([name])
}

/// Represents a customer
model Customer {
  id            String  @id @default(cuid())
  firstName     String
  lastName      String
  email         String  @unique
  phone         String?
  address       String?
  companyName   String?
  taxId         String?
  notes         String?
  loyaltyPoints Int     @default(0)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  salesOrders SalesOrder[]

  @@index([email])
}

/// Represents a warehouse storing products
model Warehouse {
  id       String        @id @default(cuid())
  name     String
  location String?
  type     WarehouseType @default(MAIN)
  capacity Int? // Optional metric for storage limits

  managerId String?
  manager   User?   @relation(fields: [managerId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  stocks         Stock[]
  stockMovements StockMovement[]
}

/// Represents the stock quantity of a product in a specific warehouse
model Stock {
  id               String @id @default(cuid())
  productId        String
  warehouseId      String
  quantity         Int    @default(0)
  reservedQuantity Int    @default(0)
  reorderLevel     Int    @default(0)

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([productId, warehouseId])
}

/// Represents a movement of stock (IN, OUT, TRANSFER, ADJUSTMENT)
model StockMovement {
  id            String                     @id @default(cuid())
  productId     String
  warehouseId   String
  type          StockMovementType
  quantity      Int // Positive or negative based on type
  referenceType StockMovementReferenceType
  referenceId   String? // Could be a PurchaseOrderId, SalesOrderId, etc.
  note          String?

  product   Product   @relation(fields: [productId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([productId, warehouseId])
  @@index([createdAt])
}

/// Represents a purchase order from a supplier
model PurchaseOrder {
  id                   String              @id @default(cuid())
  supplierId           String
  createdById          String
  status               PurchaseOrderStatus @default(PENDING)
  totalPrice           Decimal             @db.Decimal(12, 2)
  expectedDeliveryDate DateTime?
  notes                String?

  supplier  Supplier @relation(fields: [supplierId], references: [id])
  createdBy User     @relation(fields: [createdById], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  items    PurchaseOrderItem[]
  payments Payment[]           @relation("PurchaseOrderPayments")

  @@index([supplierId])
  @@index([status])
}

/// Represents an item in a purchase order
model PurchaseOrderItem {
  id              String  @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Int
  unitPrice       Decimal @db.Decimal(12, 2)
  discount        Decimal @default(0) @db.Decimal(12, 2)
  totalPrice      Decimal @db.Decimal(12, 2)

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

/// Represents a sales order from a customer
model SalesOrder {
  id              String           @id @default(cuid())
  customerId      String
  createdById     String
  status          SalesOrderStatus @default(PENDING)
  totalPrice      Decimal          @db.Decimal(12, 2)
  shippingAddress String?
  paymentStatus   PaymentStatus    @default(PENDING)

  customer  Customer @relation(fields: [customerId], references: [id])
  createdBy User     @relation(fields: [createdById], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Relations
  items    SalesOrderItem[]
  payments Payment[]        @relation("SalesOrderPayments")
  invoices Invoice[]

  @@index([customerId])
  @@index([status])
}

/// Represents an item in a sales order
model SalesOrderItem {
  id           String  @id @default(cuid())
  salesOrderId String
  productId    String
  quantity     Int
  unitPrice    Decimal @db.Decimal(12, 2)
  discount     Decimal @default(0) @db.Decimal(12, 2)
  totalPrice   Decimal @db.Decimal(12, 2)

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

/// Represents a payment (inbound or outbound)
model Payment {
  id            String        @id @default(cuid())
  orderId       String // Can map to SalesOrder or PurchaseOrder depending on `type`
  type          PaymentType
  amount        Decimal       @db.Decimal(12, 2)
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?

  // Relations mapped using separate optional fields if you want strict referential integrity
  // Alternatively, treat `orderId` as polymorphic. Here we map it explicitly to both constraints.
  purchaseOrder   PurchaseOrder? @relation("PurchaseOrderPayments", fields: [purchaseOrderId], references: [id])
  purchaseOrderId String?

  salesOrder   SalesOrder? @relation("SalesOrderPayments", fields: [salesOrderId], references: [id])
  salesOrderId String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([orderId])
  @@index([transactionId])
}

/// Represents an invoice for a sales order
model Invoice {
  id            String        @id @default(cuid())
  salesOrderId  String
  invoiceNumber String        @unique
  totalAmount   Decimal       @db.Decimal(12, 2)
  issuedAt      DateTime      @default(now())
  dueDate       DateTime?
  status        InvoiceStatus @default(DRAFT)
  pdfUrl        String?

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([invoiceNumber])
  @@index([status])
}

/// Audit log for tracking actions performed in the system
model AuditLog {
  id        String         @id @default(cuid())
  userId    String
  action    AuditLogAction
  entity    AuditLogEntity
  entityId  String
  details   Json?
  timestamp DateTime       @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([timestamp])
}

/// System activity log for tracing user login, logouts, etc.
model ActivityLog {
  id           String       @id @default(cuid())
  userId       String
  activityType ActivityType
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime     @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([activityType])
}
