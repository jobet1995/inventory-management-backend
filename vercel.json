{
  "version": 2,
  "builds": [
    {
      "src": "src/app.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["public/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/styles.css",
      "dest": "/public/styles.css"
    },
    {
      "src": "/main.js",
      "dest": "/public/main.js"
    },
    {
      "src": "/(.*)",
      "dest": "src/app.ts"
    }
  ]
}
